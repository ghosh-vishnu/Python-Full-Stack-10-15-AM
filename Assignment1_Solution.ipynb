   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Not an Armstrong Number\n"
     ]
    }
   ],
   "source": [
    "n = 145\n",
    "p = len(str(n))\n",
    "s = 0\n",
    "for i in str(n):\n",
    "    digit = int(i)\n",
    "    s = s + (digit ** p)\n",
    "if s == n:\n",
    "    print(\"Armstrong Number\")\n",
    "else:\n",
    "    print(\"Not an Armstrong Number\")"
   ]
  },
